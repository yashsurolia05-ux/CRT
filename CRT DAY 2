#include<iostream>
using namespace std;

int main() {
    int a, b;
    int max_number;
    cout << "enter 1st number: ";
    cin >> a;
    cout << "enter 2nd number: ";
    cin >> b;
    
    
     // logic for ternary operator
     max_number = (a > b) ? a : b;
