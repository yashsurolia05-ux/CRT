// Problem 1 
// Print 1 to 10 using for loop
#include <iostream>
using namespace std;

int main() {
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
}

// Problem 2
// Print even numbers from 0 to 10
#include <iostream>
using namespace std;

int main() {
    for(int i = 0; i <= 10; i += 2){
        cout << i << " ";
    }
}
